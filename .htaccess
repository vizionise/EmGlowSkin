# EmGlowSkin — URL handling for Hostinger (Apache/LiteSpeed)
# Goal: keep the clean URLs Google already indexed (/about, /facials, ...) working,
# so search rankings carry over when the site moves off GoDaddy.

Options -MultiViews
RewriteEngine On

# --- Normalize to https + non-www (Google indexed https://emglowskin.com) ---
# If HTTPS causes a redirect loop behind Hostinger's proxy, comment out the next two lines.
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# --- /index or /index.html -> / ---
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# --- /page.html -> /page (canonical clean URL, matches Google's index) ---
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --- Internally serve /page from /page.html ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# --- Custom 404 page ---
ErrorDocument 404 /404.html
